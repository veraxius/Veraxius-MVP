generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                    @id @default(uuid())
  email        String                    @unique
  password     String
  name         String?
  created_at   DateTime                  @default(now())
  participants ConversationParticipant[]
  messages     Message[]
  // AIM fields
  aimScore     Float                     @default(0)
  aimStatus    String                    @default("stable") // increasing | decreasing | decaying
  // AIM relations
  aimEvents                 AimEvent[]
  aimScoreHistory           AimScoreHistory[]
  aimChallengesAsTarget     AimChallenge[]           @relation("TargetUser")
  aimChallengesAsChallenger AimChallenge[]           @relation("ChallengerUser")
}

model Conversation {
  id           String                    @id @default(cuid())
  created_at   DateTime                  @default(now())
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  status         String       @default("sent") // sent | delivered | read
  created_at     DateTime     @default(now())
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}

// AIM MODELS
model AimEvent {
  id        String   @id @default(uuid())
  userId    String
  type      String
  value     Float
  context   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AimScoreHistory {
  id        String   @id @default(uuid())
  userId    String
  score     Float
  context   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AimChallenge {
  id              String   @id @default(uuid())
  targetUserId    String
  challengerId    String
  status          String   @default("pending")
  impact          Float?
  createdAt       DateTime @default(now())

  targetUser User @relation("TargetUser", fields: [targetUserId], references: [id])
  challenger User @relation("ChallengerUser", fields: [challengerId], references: [id])

  @@index([targetUserId])
}

// COMMUNITY FEED MODELS
model Post {
  id           Int            @id @default(autoincrement())
  userId       String
  userName     String
  userVerified Boolean        @default(false)
  content      String
  createdAt    DateTime       @default(now())
  reactions    PostReaction[]
  comments     Comment[]
}

model PostReaction {
  id      Int    @id @default(autoincrement())
  postId  Int
  userId  String
  type    String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}
