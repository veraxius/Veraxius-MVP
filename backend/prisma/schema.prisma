generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                    @id @default(uuid())
  email        String                    @unique
  password     String
  name         String?
  created_at   DateTime                  @default(now())
  lastActiveAt DateTime?
  aimConfidence Decimal?                 @db.Decimal(3, 2)
  aimDomainPrimary String?
  participants ConversationParticipant[]
  messages     Message[]
  // AIM fields
  aimScore     Float                     @default(0.5)
  aimStatus    String                    @default("stable") // increasing | decreasing | decaying
  // AIM relations
  aimEvents                 AimEvent[]
  aimScoreHistory           AimScoreHistory[]
  aimChallengesAsTarget     AimChallenge[]           @relation("TargetUser")
  aimChallengesAsChallenger AimChallenge[]           @relation("ChallengerUser")
  aimOutcomes               AimOutcome[]
  aimConsistency            AimConsistency?
  aimDomainScores           AimDomainScore[]
  aimFlags                  AimFlag[]
  // Domain system relations
  postDomains              PostDomain[]
  userDomainScores         UserDomainScore[]
  domainAimEvents          DomainAimEvent[]          @relation("DomainEventOwner")
  domainAimEventsAsVoter   DomainAimEvent[]          @relation("DomainEventVoter")
}

model Conversation {
  id           String                    @id @default(cuid())
  created_at   DateTime                  @default(now())
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  status         String       @default("sent") // sent | delivered | read
  created_at     DateTime     @default(now())
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}

// AIM MODELS
model AimEvent {
  id        String   @id @default(uuid())
  userId    String
  eventType String
  signal    String?
  delta     Float
  weight    Float       @default(1)
  domain    String?
  contextWeight Float   @default(1)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AimScoreHistory {
  id        String   @id @default(uuid())
  userId    String
  score     Float
  context   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AimChallenge {
  id              String   @id @default(uuid())
  targetUserId    String
  challengerId    String
  reason          String
  severity        Int
  status          String   @default("pending") // pending | resolved | rejected
  resolution      String?  // positive | negative
  impact          Float?
  createdAt       DateTime @default(now())

  targetUser User @relation("TargetUser", fields: [targetUserId], references: [id])
  challenger User @relation("ChallengerUser", fields: [challengerId], references: [id])

  @@index([targetUserId])
}

model AimOutcome {
  userId        String
  interactionId String
  quality       Decimal  @db.Decimal(3, 2)
  verifiedBy    String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, interactionId])
  @@index([userId])
}

model AimConsistency {
  userId       String   @id
  breakCount   Int      @default(0)
  matchCount   Int      @default(0)
  lastSnapshot Json?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AimDomainScore {
  userId           String
  domain           String
  score            Float      @default(0)
  confidence       Float      @default(0)
  interactionCount Int        @default(0)
  updatedAt        DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, domain])
  @@index([userId])
}

model AimFlag {
  userId    String
  flagType  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, flagType, createdAt])
  @@index([userId])
}

// COMMUNITY FEED MODELS
model Post {
  id           Int            @id @default(autoincrement())
  userId       String
  userName     String
  userVerified Boolean        @default(false)
  content      String
  createdAt    DateTime       @default(now())
  reactions    PostReaction[]
  comments     Comment[]
  // Domain system relations
  postDomains     PostDomain[]
  domainAimEvents DomainAimEvent[]
}

model PostReaction {
  id      Int    @id @default(autoincrement())
  postId  Int
  userId  String
  type    String
  post    Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
}

model Comment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    String
  userName  String
  content   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// DOMAIN SYSTEM MODELS

// Stores the domain classification for each post (primary + optional secondary)
model PostDomain {
  id              String   @id @default(uuid())
  postId          Int
  userId          String
  domainName      String
  confidenceScore Float    @default(0)
  isPrimary       Boolean  @default(true)
  rawKeywordScore Float    @default(0)
  classifiedAt    DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, isPrimary])
  @@index([userId])
  @@index([domainName])
}

// Per-user, per-domain AIM score
model UserDomainScore {
  id                   String    @id @default(uuid())
  userId               String
  domainName           String
  domainAimScore       Float     @default(0.50)
  domainConfidence     Float     @default(0)
  interactionCount     Int       @default(0)
  positiveSignals      Int       @default(0)
  negativeSignals      Int       @default(0)
  lastActivityAt       DateTime?
  isPublic             Boolean   @default(false)
  scoreAt7dAgo         Float?
  coordinatedBoostFlag Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domainName])
  @@index([userId])
}

// Individual AIM events scoped to a domain (audit log for recalculation)
model DomainAimEvent {
  id                   String   @id @default(uuid())
  userId               String
  postId               Int?
  domainName           String
  eventType            String
  rawDelta             Float
  variableWeight       Float    @default(1.0)
  recencyFactor        Float    @default(1.0)
  contextWeight        Float    @default(1.0)
  confidenceMultiplier Float    @default(0.75)
  antiAbuseMultiplier  Float    @default(1.0)
  effectiveDelta       Float
  voterUserId          String?
  voterAimScore        Float?
  isReversed           Boolean  @default(false)
  createdAt            DateTime @default(now())

  user      User  @relation("DomainEventOwner", fields: [userId], references: [id], onDelete: Cascade)
  post      Post? @relation(fields: [postId], references: [id], onDelete: SetNull)
  voterUser User? @relation("DomainEventVoter", fields: [voterUserId], references: [id], onDelete: SetNull)

  @@index([userId, domainName])
  @@index([postId])
}

model Event {
  id        Int      @id @default(autoincrement())
  type      String
  userId    String?
  payload   Json
  status    String   @default("pending")
  error     String?
  createdAt DateTime @default(now())
}
